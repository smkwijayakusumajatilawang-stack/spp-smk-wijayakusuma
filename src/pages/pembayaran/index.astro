---
import AppLayout from "../../layouts/AppLayout.astro";
---

<AppLayout title="Pembayaran SPP">
	<header class="mb-6">
		<p class="text-sm font-semibold uppercase tracking-[0.15em] text-[var(--brand)]">Transaksi</p>
		<h2 class="text-2xl font-black sm:text-3xl">Pembayaran Invoice</h2>
	</header>

	<!-- Rekening Tujuan Yayasan -->
	<div id="rekening-box" class="hidden mb-5 rounded-xl border border-teal-200 bg-teal-50 p-4">
		<p class="text-xs font-semibold uppercase tracking-[0.12em] text-teal-700 mb-2">Rekening Tujuan Pembayaran</p>
		<div id="rekening-list" class="flex flex-wrap gap-4"></div>
	</div>

	<section class="grid gap-4 lg:grid-cols-[420px_1fr]">
		<form id="payment-form" class="rounded-xl border border-slate-200 p-4">
			<h3 class="text-lg font-bold">Proses Pembayaran</h3>
			<div class="mt-4 space-y-3">
				<select name="student_id" id="f-student" required
					class="w-full rounded-lg border border-slate-300 px-3 py-2 bg-white">
					<option value="">Pilih siswa</option>
				</select>
				<div>
					<label class="block text-xs text-slate-500 mb-1">Tanggal Bayar</label>
					<input name="payment_date" id="f-date" type="date" required
						class="w-full rounded-lg border border-slate-300 px-3 py-2" />
				</div>
			</div>

			<div class="mt-5" id="invoice-checklist">
				<p class="text-sm text-slate-400">Pilih siswa untuk melihat tagihan.</p>
			</div>

			<div class="mt-4 hidden" id="pay-summary">
				<div class="rounded-lg bg-slate-50 p-3 text-sm space-y-1">
					<div class="flex justify-between">
						<span class="text-slate-500">Total tagihan dipilih</span>
						<span id="sum-total" class="font-semibold">Rp 0</span>
					</div>
					<div class="flex justify-between">
						<span class="text-slate-500">Total dibayar</span>
						<span id="sum-paid" class="font-semibold text-green-700">Rp 0</span>
					</div>
					<div class="flex justify-between border-t pt-1">
						<span class="text-slate-500">Sisa</span>
						<span id="sum-due" class="font-semibold text-red-600">Rp 0</span>
					</div>
				</div>
			</div>

			<button type="submit"
				class="mt-4 w-full rounded-lg bg-[var(--brand)] px-4 py-2 font-semibold text-white disabled:opacity-40"
				id="btn-pay" disabled>
				Proses Pembayaran
			</button>
		</form>

		<div class="rounded-xl border border-slate-200 p-4">
			<h3 class="text-lg font-bold">Riwayat Pembayaran</h3>
			<div class="mt-3 overflow-x-auto">
				<table class="min-w-full text-sm">
					<thead class="border-b bg-slate-50 text-left text-xs uppercase text-slate-500">
						<tr>
							<th class="px-3 py-2">Tanggal</th>
							<th class="px-3 py-2">Siswa</th>
							<th class="px-3 py-2">Total Tagihan</th>
							<th class="px-3 py-2">Dibayar</th>
							<th class="px-3 py-2">Sisa</th>
							<th class="px-3 py-2">Status</th>
						</tr>
					</thead>
					<tbody id="payments-body"></tbody>
				</table>
			</div>
		</div>
	</section>

	<script>
		import { createClient } from "@supabase/supabase-js";

		const supabase = createClient(
			import.meta.env.PUBLIC_SUPABASE_URL,
			import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
		);
		const idr = new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", maximumFractionDigits: 0 });

		const form = document.getElementById("payment-form") as HTMLFormElement;
		const studentEl = document.getElementById("f-student") as HTMLSelectElement;
		const dateEl = document.getElementById("f-date") as HTMLInputElement;
		const checklist = document.getElementById("invoice-checklist") as HTMLElement;
		const historyBody = document.getElementById("payments-body") as HTMLElement;
		const paySummary = document.getElementById("pay-summary") as HTMLElement;
		const btnPay = document.getElementById("btn-pay") as HTMLButtonElement;

		const STATE_BADGE: Record<string, string> = {
			draft: "bg-slate-100 text-slate-600",
			partial: "bg-amber-100 text-amber-700",
			paid: "bg-green-100 text-green-700",
			done: "bg-blue-100 text-blue-700",
		};
		const STATE_LABEL: Record<string, string> = { draft: "Draft", partial: "Sebagian", paid: "Lunas", done: "Selesai" };

		dateEl.value = new Date().toISOString().slice(0, 10);

		async function loadRekening() {
			const { data } = await supabase
				.from("bank_accounts")
				.select("bank_name,account_no,account_name,notes")
				.eq("is_active", true)
				.order("created_at", { ascending: true });

			const box = document.getElementById("rekening-box");
			const list = document.getElementById("rekening-list");
			if (!data?.length || !box || !list) return;

			list.innerHTML = data.map((r) => `
				<div class="rounded-lg border border-teal-300 bg-white px-4 py-3 min-w-[200px]">
					<p class="text-xs font-bold uppercase tracking-wide text-teal-700">${r.bank_name}</p>
					<p class="mt-1 font-mono text-base font-bold text-slate-800">${r.account_no}</p>
					<p class="text-xs text-slate-500">a.n. ${r.account_name}</p>
					${r.notes ? `<p class="mt-1 text-xs text-slate-400">${r.notes}</p>` : ""}
				</div>
			`).join("");
			box.classList.remove("hidden");
		}

		function updateSummary() {
			const checks = [...checklist.querySelectorAll('input[data-role="invoice-check"]:checked')] as HTMLInputElement[];
			let total = 0;
			let paid = 0;
			checks.forEach((node) => {
				const invoiceId = node.value;
				const amountEl = checklist.querySelector(`input[data-role="pay-amount"][data-invoice-id="${invoiceId}"]`) as HTMLInputElement | null;
				const due = Number(node.dataset.due || 0);
				const paying = Math.min(due, Math.max(0, Number(amountEl?.value || 0)));
				total += due;
				paid += paying;
			});
			(document.getElementById("sum-total") as HTMLElement).textContent = idr.format(total);
			(document.getElementById("sum-paid") as HTMLElement).textContent = idr.format(paid);
			(document.getElementById("sum-due") as HTMLElement).textContent = idr.format(total - paid);
			paySummary.classList.toggle("hidden", checks.length === 0);
			btnPay.disabled = checks.length === 0;
		}

		async function loadStudents() {
			const { data, error } = await supabase.from("students").select("id,name").order("name");
			if (error) return alert(error.message);
			studentEl.innerHTML =
				'<option value="">Pilih siswa</option>' +
				(data || []).map((x) => `<option value="${x.id}">${x.name}</option>`).join("");
		}

		async function loadUnpaidInvoices(studentId) {
			if (!studentId) {
				checklist.innerHTML = `<p class="text-sm text-slate-400">Pilih siswa untuk melihat tagihan.</p>`;
				paySummary.classList.add("hidden");
				btnPay.disabled = true;
				return;
			}

			const { data, error } = await supabase
				.from("invoices")
				.select("id,total_amount,paid_amount,components(name),billing_periods(name)")
				.eq("student_id", studentId)
				.in("status", ["draft", "posted"])
				.order("created_at", { ascending: true });

			if (error) return alert(error.message);

			if (!data?.length) {
				checklist.innerHTML = `<p class="text-sm text-slate-400">Tidak ada tagihan aktif untuk siswa ini.</p>`;
				paySummary.classList.add("hidden");
				btnPay.disabled = true;
				return;
			}

			checklist.innerHTML = data
				.map((inv) => {
					const due = Number(inv.total_amount || 0) - Number(inv.paid_amount || 0);
					return `<label class="flex flex-col gap-1 rounded-lg border border-slate-200 p-3 cursor-pointer hover:bg-slate-50">
						<div class="flex items-start gap-2">
							<input type="checkbox" class="mt-0.5" data-role="invoice-check"
								value="${inv.id}" data-due="${due}" />
							<span class="font-medium text-sm">${inv.components?.name ?? "-"} — ${inv.billing_periods?.name ?? "-"}</span>
						</div>
						<p class="ml-5 text-xs text-slate-500">Sisa tagihan: <strong>${idr.format(due)}</strong></p>
						<input type="number" min="0" step="1000" value="${due}"
							data-role="pay-amount" data-invoice-id="${inv.id}"
							class="ml-5 mt-1 w-full rounded-lg border border-slate-300 px-3 py-1.5 text-sm" />
					</label>`;
				})
				.join("");

			// Update summary on any change
			checklist.addEventListener("change", updateSummary);
			checklist.addEventListener("input", updateSummary);
			updateSummary();
		}

		async function loadHistory() {
			const { data, error } = await supabase
				.from("payments")
				.select("payment_date,state,amount_total,amount_paid,amount_due,students(name)")
				.order("created_at", { ascending: false });

			if (error) {
				historyBody.innerHTML = `<tr><td class="px-3 py-3 text-red-600" colspan="6">${error.message}</td></tr>`;
				return;
			}

			historyBody.innerHTML = (data || [])
				.map((p) => {
					const badge = STATE_BADGE[p.state] ?? "bg-slate-100 text-slate-600";
					const label = STATE_LABEL[p.state] ?? p.state;
					return `<tr class="border-b">
						<td class="px-3 py-2">${p.payment_date}</td>
						<td class="px-3 py-2">${p.students?.name ?? "-"}</td>
						<td class="px-3 py-2">${idr.format(Number(p.amount_total || 0))}</td>
						<td class="px-3 py-2">${idr.format(Number(p.amount_paid || 0))}</td>
						<td class="px-3 py-2">${idr.format(Number(p.amount_due || 0))}</td>
						<td class="px-3 py-2">
							<span class="rounded-full px-2 py-0.5 text-xs font-medium ${badge}">${label}</span>
						</td>
					</tr>`;
				})
				.join("");
		}

		studentEl.addEventListener("change", () => loadUnpaidInvoices(studentEl.value));

		form.addEventListener("submit", async (e) => {
			e.preventDefault();
			const studentId = studentEl.value;
			const checked = [...checklist.querySelectorAll('input[data-role="invoice-check"]:checked')];
			if (!checked.length) return alert("Pilih minimal 1 tagihan.");

			const payload = checked.map((node) => {
				const invoiceId = node.value;
				const due = Number(node.dataset.due || 0);
				const amountEl = checklist.querySelector(
					`input[data-role="pay-amount"][data-invoice-id="${invoiceId}"]`,
				);
				return { invoiceId, amountPaid: Math.min(due, Math.max(0, Number(amountEl?.value || 0))), due };
			});

			// Ambil data invoice terkini untuk validasi
			const ids = payload.map((x) => x.invoiceId);
			const { data: invoiceRows, error: fetchErr } = await supabase
				.from("invoices")
				.select("id,total_amount,paid_amount")
				.in("id", ids);
			if (fetchErr) return alert(fetchErr.message);

			type SummaryLine = { invoiceId: string; due: number; pay: number; currentPaid: number; total: number };
			const summary = payload.reduce(
				(acc: { total: number; paid: number; lines: SummaryLine[] }, line) => {
					const inv = invoiceRows!.find((x) => x.id === line.invoiceId);
					const due = Number(inv?.total_amount || 0) - Number(inv?.paid_amount || 0);
					const safePay = Math.min(due, Math.max(0, line.amountPaid));
					acc.total += due;
					acc.paid += safePay;
					acc.lines.push({
						invoiceId: line.invoiceId,
						due,
						pay: safePay,
						currentPaid: Number(inv?.paid_amount || 0),
						total: Number(inv?.total_amount || 0),
					});
					return acc;
				},
				{ total: 0, paid: 0, lines: [] as SummaryLine[] },
			);

			if (summary.paid === 0) return alert("Jumlah bayar tidak boleh 0.");

			const state =
				summary.paid === 0 ? "draft" : summary.paid < summary.total ? "partial" : "paid";

			// Insert payment header
			const { data: paymentData, error: payErr } = await supabase
				.from("payments")
				.insert({
					student_id: studentId,
					payment_date: dateEl.value,
					state,
					amount_total: summary.total,
					amount_paid: summary.paid,
					amount_due: summary.total - summary.paid,
				})
				.select("id")
				.single();
			if (payErr) return alert(payErr.message);

			// Insert payment lines
			const linesToInsert = summary.lines
				.filter((x) => x.pay > 0)
				.map((x) => ({
					payment_id: paymentData.id,
					invoice_id: x.invoiceId,
					amount_total: x.due,
					amount_paid: x.pay,
					amount_residual: x.due - x.pay,
				}));

			if (linesToInsert.length) {
				const { error: linesErr } = await supabase.from("payment_lines").insert(linesToInsert);
				if (linesErr) return alert(linesErr.message);
			}

			// Update invoice paid_amount & status
			for (const line of summary.lines) {
				if (line.pay <= 0) continue;
				const nextPaid = line.currentPaid + line.pay;
				const invoiceStatus = nextPaid >= line.total ? "paid" : "posted";
				const { error: updErr } = await supabase
					.from("invoices")
					.update({ paid_amount: nextPaid, status: invoiceStatus })
					.eq("id", line.invoiceId);
				if (updErr) return alert(updErr.message);
			}

			// Reset form
			dateEl.value = new Date().toISOString().slice(0, 10);
			await loadUnpaidInvoices(studentId); // reload tagihan siswa yg sama
			await loadHistory();
		});

		await Promise.all([loadStudents(), loadHistory(), loadRekening()]);
	</script>
</AppLayout>
