---
import AppLayout from "../../layouts/AppLayout.astro";
---

<AppLayout title="Tagihan Siswa">
	<header class="mb-6">
		<p class="text-sm font-semibold uppercase tracking-[0.15em] text-[var(--brand)]">Transaksi</p>
		<h2 class="text-2xl font-black sm:text-3xl">Tagihan Siswa</h2>
	</header>

	<section class="grid gap-4 lg:grid-cols-[460px_1fr]">
		<form id="invoice-form" class="rounded-xl border border-slate-200 p-4">
			<h3 id="form-title" class="text-lg font-bold">Buat Tagihan</h3>
			<input type="hidden" id="edit-id" />
			<div class="mt-4 space-y-3">
				<select name="class_id" id="f-class" required
					class="w-full rounded-lg border border-slate-300 px-3 py-2 bg-white">
					<option value="">Pilih kelas</option>
				</select>
				<select name="student_id" id="f-student" required disabled
					class="w-full rounded-lg border border-slate-300 px-3 py-2 bg-white disabled:bg-slate-100 disabled:cursor-not-allowed">
					<option value="">Pilih kelas terlebih dahulu</option>
				</select>
				<select name="period_id" id="f-period" required
					class="w-full rounded-lg border border-slate-300 px-3 py-2 bg-white">
					<option value="">Pilih periode</option>
				</select>
				<select name="component_id" id="f-component" required
					class="w-full rounded-lg border border-slate-300 px-3 py-2 bg-white">
					<option value="">Pilih komponen</option>
				</select>
				<input name="total_amount" id="f-amount" type="number" min="0" step="1000" required
					placeholder="Nominal tagihan"
					class="w-full rounded-lg border border-slate-300 px-3 py-2" />
				<select name="status" id="f-status" class="w-full rounded-lg border border-slate-300 px-3 py-2 bg-white">
					<option value="posted">Ditagih (Posted)</option>
					<option value="draft">Draft</option>
				</select>
			</div>
			<div class="mt-4 flex gap-2">
				<button type="submit"
					class="rounded-lg bg-[var(--brand)] px-4 py-2 font-semibold text-white">
					Simpan Tagihan
				</button>
				<button type="button" id="btn-cancel"
					class="hidden rounded-lg border border-slate-300 px-4 py-2 font-semibold">
					Batal
				</button>
			</div>
		</form>

		<div class="rounded-xl border border-slate-200 p-4">
			<div class="mb-3 flex flex-wrap items-center justify-between gap-2">
				<h3 class="text-lg font-bold">Daftar Tagihan</h3>
				<div class="flex gap-2">
					<select id="filter-class"
						class="rounded-lg border border-slate-300 px-3 py-1.5 text-sm bg-white">
						<option value="">Semua Kelas</option>
					</select>
					<select id="filter-status"
						class="rounded-lg border border-slate-300 px-3 py-1.5 text-sm bg-white">
						<option value="">Semua status</option>
						<option value="draft">Draft</option>
						<option value="posted">Ditagih</option>
						<option value="paid">Lunas</option>
						<option value="cancelled">Dibatalkan</option>
					</select>
				</div>
			</div>
			<div class="overflow-x-auto">
				<table class="min-w-full text-sm">
					<thead class="border-b bg-slate-50 text-left text-xs uppercase text-slate-500">
						<tr>
							<th class="px-3 py-2">Siswa</th>
							<th class="px-3 py-2">Komponen</th>
							<th class="px-3 py-2">Periode</th>
							<th class="px-3 py-2">Total</th>
							<th class="px-3 py-2">Terbayar</th>
							<th class="px-3 py-2">Status</th>
							<th class="px-3 py-2">Tgl/Wkt Lunas</th>
							<th class="px-3 py-2">Aksi</th>
						</tr>
					</thead>
					<tbody id="invoices-body"></tbody>
				</table>
			</div>
		</div>
	</section>

	<!-- Modal Edit Tanggal/Waktu Lunas -->
	<div id="modal-lunas" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/40">
		<div class="w-full max-w-sm rounded-2xl bg-white p-6 shadow-xl">
			<h3 class="text-lg font-bold mb-4">Edit Tanggal &amp; Waktu Lunas</h3>
			<input type="hidden" id="modal-invoice-id" />
			<div class="space-y-3">
				<div>
					<label class="block text-xs font-semibold text-slate-500 mb-1">Tanggal Lunas</label>
					<input type="date" id="modal-date"
						class="w-full rounded-lg border border-slate-300 px-3 py-2" />
				</div>
				<div>
					<label class="block text-xs font-semibold text-slate-500 mb-1">Waktu Lunas</label>
					<input type="time" id="modal-time"
						class="w-full rounded-lg border border-slate-300 px-3 py-2" />
				</div>
			</div>
			<div class="mt-5 flex gap-2 justify-end">
				<button id="modal-cancel"
					class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold hover:bg-slate-50">
					Batal
				</button>
				<button id="modal-save"
					class="rounded-lg bg-[var(--brand)] px-4 py-2 text-sm font-semibold text-white hover:opacity-90">
					Simpan
				</button>
			</div>
		</div>
	</div>

	<script>
		import { createClient } from "@supabase/supabase-js";

		const supabase = createClient(
			import.meta.env.PUBLIC_SUPABASE_URL,
			import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
		);
		const idr = new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", maximumFractionDigits: 0 });

		const form = document.getElementById("invoice-form");
		const formTitle = document.getElementById("form-title");
		const editIdInput = document.getElementById("edit-id");
		const btnCancel = document.getElementById("btn-cancel");
		const body = document.getElementById("invoices-body");
		const filterStatus = document.getElementById("filter-status");
		const filterClass = document.getElementById("filter-class");

		const STATUS_BADGE = {
			draft: "bg-slate-100 text-slate-600",
			posted: "bg-blue-100 text-blue-700",
			paid: "bg-green-100 text-green-700",
			cancelled: "bg-red-100 text-red-600",
		};
		const STATUS_LABEL = { draft: "Draft", posted: "Ditagih", paid: "Lunas", cancelled: "Dibatalkan" };

		const invoiceMap = new Map();
		let componentData = [];

		function resetForm() {
			form.reset();
			editIdInput.value = "";
			formTitle.textContent = "Buat Tagihan";
			btnCancel.classList.add("hidden");
		}

		let allStudents = [];
		let allClasses = [];

		async function loadSelectors() {
			const [students, components, periods, classes] = await Promise.all([
				supabase.from("students").select("id,name,class_id").order("name"),
				supabase.from("components").select("id,name,default_amount").eq("is_active", true).order("name"),
				supabase
					.from("billing_periods")
					.select("id,name,start_date")
					.order("start_date", { ascending: false }),
				supabase.from("classes").select("id,name").order("name"),
			]);

			if (students.error) return alert(students.error.message);
			if (components.error) return alert(components.error.message);
			if (periods.error) return alert(periods.error.message);
			if (classes.error) return alert(classes.error.message);

			componentData = components.data || [];
			allStudents = students.data || [];
			allClasses = classes.data || [];

			const fStudent = document.getElementById("f-student") as HTMLSelectElement;
			const fComponent = document.getElementById("f-component") as HTMLSelectElement;
			const fPeriod = document.getElementById("f-period") as HTMLSelectElement;
			const fClass = document.getElementById("f-class") as HTMLSelectElement;

			// Populate filter class dropdown
			if (filterClass) {
				filterClass.innerHTML =
					'<option value="">Semua Kelas</option>' +
					allClasses.map((x: any) => `<option value="${x.id}">${x.name}</option>`).join("");
			}

			// Populate class dropdown
			fClass.innerHTML =
				'<option value="">Pilih kelas</option>' +
				allClasses.map((x: any) => `<option value="${x.id}">${x.name}</option>`).join("");

			// When class changes, enable student dropdown
			fClass.addEventListener("change", () => {
				const classId = fClass.value;
				if (classId) {
					fStudent.disabled = false;
					const filtered = allStudents.filter((s: any) => s.class_id === classId);
					fStudent.innerHTML =
						'<option value="">Pilih siswa</option>' +
						filtered.map((x: any) => `<option value="${x.id}">${x.name}</option>`).join("");
				} else {
					fStudent.disabled = true;
					fStudent.innerHTML = '<option value="">Pilih kelas terlebih dahulu</option>';
				}
			});

			fComponent.innerHTML =
				'<option value="">Pilih komponen</option>' +
				componentData.map((x) => `<option value="${x.id}">${x.name}</option>`).join("");
			fPeriod.innerHTML =
				'<option value="">Pilih periode</option>' +
				(periods.data || []).map((x: any) => `<option value="${x.id}">${x.name}</option>`).join("");

			// Auto-isi nominal dari default komponen
			fComponent.addEventListener("change", () => {
				const found = componentData.find((x: any) => x.id === fComponent.value);
				if (found) (document.getElementById("f-amount") as HTMLInputElement).value = String(found.default_amount || 0);
			});
		}

		async function loadInvoices() {
			let query = supabase
				.from("invoices")
				.select(
					"id,status,total_amount,paid_amount,paid_off_at,student_id,component_id,period_id,students(name,class_id,classes(name)),components(name),billing_periods(name)",
				)
				.order("created_at", { ascending: false });

			const statusFilter = filterStatus.value;
			if (statusFilter) query = query.eq("status", statusFilter);

			const { data, error } = await query;

			if (error) {
				body.innerHTML = `<tr><td class="px-3 py-3 text-red-600" colspan="8">${error.message}</td></tr>`;
				return;
			}

			invoiceMap.clear();
			
			// Client-side filter by class
			let filteredData = data || [];
			const classFilter = filterClass?.value;
			if (classFilter) {
				filteredData = filteredData.filter((item: any) => item.students?.class_id === classFilter);
			}
			
			filteredData.forEach((inv: any) => invoiceMap.set(inv.id, inv));

			body.innerHTML = filteredData
				.map((item: any) => {
					const badge = STATUS_BADGE[item.status] ?? "bg-slate-100 text-slate-600";
					const label = STATUS_LABEL[item.status] ?? item.status;
					const canEdit = item.status === "draft";
					const canCancel = item.status === "draft" || item.status === "posted";
					const isPaid = item.status === "paid";

					// Format tanggal & waktu lunas
					let tglLunas = "-";
					let wktLunas = "";
					if (item.paid_off_at) {
						const dt = new Date(item.paid_off_at);
						tglLunas = dt.toLocaleDateString("id-ID", { day: "2-digit", month: "short", year: "numeric" });
						wktLunas = dt.toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" });
					}

					const paidOffCell = isPaid
						? `<div class="text-xs font-medium text-slate-700">${tglLunas}</div>
						   ${wktLunas ? `<div class="text-xs text-slate-500">${wktLunas}</div>` : ""}`
						: `<span class="text-xs text-slate-400">-</span>`;

					return `<tr class="border-b ${item.status === "cancelled" ? "opacity-50" : ""}">
						<td class="px-3 py-2">${item.students?.name ?? "-"}</td>
						<td class="px-3 py-2">${item.components?.name ?? "-"}</td>
						<td class="px-3 py-2">${item.billing_periods?.name ?? "-"}</td>
						<td class="px-3 py-2">${idr.format(Number(item.total_amount || 0))}</td>
						<td class="px-3 py-2">${idr.format(Number(item.paid_amount || 0))}</td>
						<td class="px-3 py-2">
							<span class="rounded-full px-2 py-0.5 text-xs font-medium ${badge}">${label}</span>
						</td>
						<td class="px-3 py-2">${paidOffCell}</td>
						<td class="px-3 py-2 space-x-2 whitespace-nowrap">
							${canEdit ? `<button data-id="${item.id}" data-action="edit" class="text-blue-600 hover:underline text-xs">Edit</button>` : ""}
							${canCancel ? `<button data-id="${item.id}" data-action="cancel" class="text-red-600 hover:underline text-xs">Batalkan</button>` : ""}
							${isPaid ? `<button data-id="${item.id}" data-action="edit-lunas" class="text-green-700 hover:underline text-xs">Edit Tgl</button>` : ""}
							${isPaid ? `<a href="/laporan/mutasi" class="text-indigo-600 hover:underline text-xs">Mutasi</a>` : ""}
						</td>
					</tr>`;
				})
				.join("");
		}

		body.addEventListener("click", async (e) => {
			const btn = e.target.closest("button[data-action]");
			if (!btn) return;
			const { id, action } = btn.dataset;
			const item = invoiceMap.get(id);
			if (!item) return;

			if (action === "edit") {
				formTitle.textContent = "Edit Tagihan";
				editIdInput.value = item.id;
				document.getElementById("f-student").value = item.student_id ?? "";
				document.getElementById("f-component").value = item.component_id ?? "";
				document.getElementById("f-period").value = item.period_id ?? "";
				document.getElementById("f-amount").value = String(item.total_amount || 0);
				document.getElementById("f-status").value = item.status;
				btnCancel.classList.remove("hidden");
				window.scrollTo({ top: 0, behavior: "smooth" });
			}

			if (action === "cancel") {
				if (!confirm("Batalkan tagihan ini?")) return;
				const { error } = await supabase
					.from("invoices")
					.update({ status: "cancelled" })
					.eq("id", id);
				if (error) return alert(error.message);
				await loadInvoices();
			}

			if (action === "edit-lunas") {
				const modal = document.getElementById("modal-lunas");
				const modalId = document.getElementById("modal-invoice-id");
				const modalDate = document.getElementById("modal-date");
				const modalTime = document.getElementById("modal-time");
				modalId.value = item.id;
				if (item.paid_off_at) {
					const dt = new Date(item.paid_off_at);
					modalDate.value = dt.toISOString().slice(0, 10);
					modalTime.value = dt.toTimeString().slice(0, 5);
				} else {
					const now = new Date();
					modalDate.value = now.toISOString().slice(0, 10);
					modalTime.value = now.toTimeString().slice(0, 5);
				}
				modal.classList.remove("hidden");
			}
		});

		// Modal controls
		document.getElementById("modal-cancel").addEventListener("click", () => {
			document.getElementById("modal-lunas").classList.add("hidden");
		});
		document.getElementById("modal-lunas").addEventListener("click", (e) => {
			if (e.target === e.currentTarget) e.currentTarget.classList.add("hidden");
		});
		document.getElementById("modal-save").addEventListener("click", async () => {
			const modalId = document.getElementById("modal-invoice-id");
			const modalDate = document.getElementById("modal-date");
			const modalTime = document.getElementById("modal-time");
			const id = modalId.value;
			if (!id || !modalDate.value) return alert("Tanggal lunas wajib diisi.");
			const timeStr = modalTime.value || "00:00";
			const paidOffAt = new Date(`${modalDate.value}T${timeStr}:00`).toISOString();
			const { error } = await supabase
				.from("invoices")
				.update({ paid_off_at: paidOffAt })
				.eq("id", id);
			if (error) return alert(error.message);
			document.getElementById("modal-lunas").classList.add("hidden");
			await loadInvoices();
		});

		filterStatus.addEventListener("change", loadInvoices);
		filterClass?.addEventListener("change", loadInvoices);
		btnCancel.addEventListener("click", resetForm);

		form.addEventListener("submit", async (e) => {
			e.preventDefault();
			const fd = new FormData(form);
			const isEdit = !!editIdInput.value;
			const payload = {
				student_id: fd.get("student_id"),
				component_id: fd.get("component_id"),
				period_id: fd.get("period_id"),
				total_amount: Number(fd.get("total_amount")),
				status: fd.get("status"),
			};

			if (isEdit) {
				const { error } = await supabase
					.from("invoices")
					.update(payload)
					.eq("id", editIdInput.value);
				if (error) return alert(error.message);
			} else {
				const { error } = await supabase.from("invoices").insert(payload);
				if (error) return alert(error.message);
			}

			resetForm();
			await loadInvoices();
		});

		await loadSelectors();
		await loadInvoices();
	</script>
</AppLayout>
