---
import AppLayout from "../../layouts/AppLayout.astro";
---

<AppLayout title="Master Kelas">
	<header class="mb-6">
		<p class="text-sm font-semibold uppercase tracking-[0.15em] text-[var(--brand)]">Master Data</p>
		<h2 class="text-2xl font-black sm:text-3xl">Kelas</h2>
		<p class="mt-1 text-sm text-slate-500">
			Kelas harus dibuat terlebih dahulu sebelum mendaftarkan siswa.
			Buat <a href="/master/periode" class="text-[var(--brand)] hover:underline">tahun ajaran</a> terlebih dahulu jika belum ada.
		</p>
	</header>

	<section class="grid gap-4 lg:grid-cols-[380px_1fr]">
		<form id="class-form" class="rounded-xl border border-slate-200 p-4">
			<h3 id="form-title" class="text-lg font-bold">Tambah Kelas</h3>
			<input type="hidden" id="edit-id" />
			<div class="mt-4 space-y-3">
				<select
					name="academic_year_id"
					id="f-year"
					required
					class="w-full rounded-lg border border-slate-300 px-3 py-2 bg-white"
				>
					<option value="">-- Memuat tahun ajaran... --</option>
				</select>
				<select
					name="jenjang"
					id="f-jenjang"
					required
					class="w-full rounded-lg border border-slate-300 px-3 py-2 bg-white"
				>
					<option value="">-- Pilih Jenjang --</option>
					<option value="SMK">SMK</option>
				</select>
				<input
					name="name"
					id="f-name"
					required
					placeholder="Nama kelas (contoh: 7A, X IPA 1)"
					class="w-full rounded-lg border border-slate-300 px-3 py-2"
				/>
			</div>
			<div class="mt-4 flex gap-2">
				<button
					type="submit"
					class="rounded-lg bg-[var(--brand)] px-4 py-2 font-semibold text-white"
				>
					Simpan
				</button>
				<button
					type="button"
					id="btn-cancel"
					class="hidden rounded-lg border border-slate-300 px-4 py-2 font-semibold"
				>
					Batal
				</button>
			</div>
		</form>

		<div class="rounded-xl border border-slate-200 p-4">
			<div class="flex flex-wrap items-center justify-between gap-3">
				<h3 class="text-lg font-bold">Daftar Kelas</h3>
				<div class="flex flex-wrap gap-2">
					<select id="filter-jenjang" class="rounded-lg border border-slate-300 px-3 py-1.5 text-sm bg-white">
						<option value="">Semua jenjang</option>
						<option value="SMK">SMK</option>
					</select>
					<select id="filter-year" class="rounded-lg border border-slate-300 px-3 py-1.5 text-sm bg-white">
						<option value="">Semua tahun ajaran</option>
					</select>
				</div>
			</div>
			<div class="mt-3 overflow-x-auto">
				<table class="min-w-full text-sm">
					<thead class="border-b bg-slate-50 text-left text-xs uppercase text-slate-500">
						<tr>
							<th class="px-3 py-2">Nama Kelas</th>
							<th class="px-3 py-2">Jenjang</th>
							<th class="px-3 py-2">Tahun Ajaran</th>
							<th class="px-3 py-2">Aksi</th>
						</tr>
					</thead>
					<tbody id="classes-body"></tbody>
				</table>
			</div>
		</div>
	</section>

	<script>
		import { createClient } from "@supabase/supabase-js";

		const supabase = createClient(
			import.meta.env.PUBLIC_SUPABASE_URL,
			import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
		);

		const form = document.getElementById("class-form");
		const formTitle = document.getElementById("form-title");
		const editIdInput = document.getElementById("edit-id");
		const btnCancel = document.getElementById("btn-cancel");
		const body = document.getElementById("classes-body");
		const yearSelect = document.getElementById("f-year");
		const filterYear = document.getElementById("filter-year");
		const filterJenjang = document.getElementById("filter-jenjang");
		const classMap = new Map();

		const JENJANG_BADGE: Record<string, string> = {
			SMK: "bg-purple-100 text-purple-700",
		};

		function resetForm() {
			form.reset();
			editIdInput.value = "";
			formTitle.textContent = "Tambah Kelas";
			btnCancel.classList.add("hidden");
		}

		function jenjangBadge(j: string) {
			const cls = JENJANG_BADGE[j] ?? "bg-slate-100 text-slate-500";
			return j ? `<span class="rounded-full px-2 py-0.5 text-[10px] font-bold uppercase ${cls}">${j}</span>` : "-";
		}

		async function loadYears() {
			const { data, error } = await supabase
				.from("academic_years")
				.select("id,name,is_active")
				.order("name");

			if (error || !data?.length) {
				yearSelect.innerHTML = '<option value="">-- Belum ada tahun ajaran --</option>';
				yearSelect.disabled = true;
				return;
			}

			const options = data
				.map((y) => `<option value="${y.id}">${y.name}${y.is_active ? " (aktif)" : ""}</option>`)
				.join("");
			yearSelect.innerHTML = '<option value="">-- Pilih Tahun Ajaran --</option>' + options;
			yearSelect.disabled = false;

			filterYear.innerHTML =
				'<option value="">Semua tahun ajaran</option>' +
				data.map((y) => `<option value="${y.id}">${y.name}</option>`).join("");

			// Default filter ke tahun aktif jika ada
			const active = data.find((y) => y.is_active);
			if (active) filterYear.value = active.id;
		}

		async function loadClasses() {
			const filterVal = (filterYear as HTMLSelectElement).value;
			const filterJenjangVal = (filterJenjang as HTMLSelectElement).value;
			let query = supabase
				.from("classes")
				.select("id,name,jenjang,academic_year_id,academic_years(name,is_active)")
				.order("jenjang")
				.order("name");
			if (filterVal) query = query.eq("academic_year_id", filterVal);
			if (filterJenjangVal) query = query.eq("jenjang", filterJenjangVal);

			const { data, error } = await query;

			if (error) {
				body.innerHTML = `<tr><td class="px-3 py-3 text-red-600" colspan="4">${error.message}</td></tr>`;
				return;
			}

			if (!data?.length) {
				body.innerHTML = `<tr><td class="px-3 py-4 text-center text-slate-400" colspan="4">Belum ada kelas.</td></tr>`;
				return;
			}

			classMap.clear();
			data.forEach((c) => classMap.set(c.id, c));

			body.innerHTML = data
				.map(
					(item) => `<tr class="border-b">
						<td class="px-3 py-2 font-medium">${item.name}</td>
						<td class="px-3 py-2">${jenjangBadge(item.jenjang)}</td>
						<td class="px-3 py-2">
							${(item.academic_years as any)?.name ?? "-"}
							${(item.academic_years as any)?.is_active ? '<span class="ml-1 rounded-full bg-green-100 px-1.5 py-0.5 text-[10px] text-green-700">aktif</span>' : ""}
						</td>
						<td class="px-3 py-2 space-x-2 whitespace-nowrap">
							<button data-id="${item.id}" data-action="edit"
								class="text-blue-600 hover:underline text-xs">Edit</button>
							<button data-id="${item.id}" data-action="delete"
								class="text-red-600 hover:underline text-xs">Hapus</button>
						</td>
					</tr>`,
				)
				.join("");
		}

		body.addEventListener("click", async (e) => {
			const btn = e.target.closest("button[data-action]");
			if (!btn) return;
			const { id, action } = btn.dataset;
			const item = classMap.get(id);
			if (!item) return;

			if (action === "edit") {
				formTitle.textContent = "Edit Kelas";
				(editIdInput as HTMLInputElement).value = item.id;
				(document.getElementById("f-year") as HTMLSelectElement).value = item.academic_year_id ?? "";
				(document.getElementById("f-jenjang") as HTMLSelectElement).value = item.jenjang ?? "";
				(document.getElementById("f-name") as HTMLInputElement).value = item.name;
				btnCancel!.classList.remove("hidden");
				window.scrollTo({ top: 0, behavior: "smooth" });
			}

			if (action === "delete") {
				if (!confirm(`Hapus kelas "${item.name}"?`)) return;
				const { error } = await supabase.from("classes").delete().eq("id", id);
				if (error) return alert(error.message);
				await loadClasses();
			}
		});

		btnCancel.addEventListener("click", resetForm);
		filterYear.addEventListener("change", loadClasses);
		filterJenjang.addEventListener("change", loadClasses);

		form.addEventListener("submit", async (e) => {
			e.preventDefault();
			const fd = new FormData(form);
			const isEdit = !!editIdInput.value;
			const payload = {
				name: fd.get("name"),
				jenjang: fd.get("jenjang") || null,
				academic_year_id: fd.get("academic_year_id"),
			};

			if (isEdit) {
				const { error } = await supabase
					.from("classes")
					.update(payload)
					.eq("id", editIdInput.value);
				if (error) return alert(error.message);
			} else {
				const { error } = await supabase.from("classes").insert(payload);
				if (error) return alert(error.message);
			}

			resetForm();
			await loadClasses();
		});

		await loadYears();
		await loadClasses();
	</script>
</AppLayout>
