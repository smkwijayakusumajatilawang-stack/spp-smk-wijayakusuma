---
import "../styles/global.css";

interface Props {
	title: string;
}

const { title } = Astro.props;
const path = Astro.url.pathname;

const navLink = (href: string) => {
	const active = href === "/" ? path === "/" : path.startsWith(href);
	return `block rounded-lg px-3 py-2 hover:bg-white/10 transition-colors${active ? " bg-white/20 font-semibold" : ""}`;
};
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} — SPP Areta</title>
	</head>
	<body class="min-h-screen bg-[var(--bg)]">

		<!-- Mobile Topbar (visible hanya di layar kecil) -->
		<header class="sticky top-0 z-30 flex items-center gap-3 bg-[var(--ink)] px-4 py-3 text-white shadow-lg lg:hidden">
			<button
				id="menu-toggle"
				aria-label="Buka menu navigasi"
				class="rounded-lg p-1.5 hover:bg-white/10 transition-colors"
			>
				<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</button>
			<div>
				<p class="text-[10px] uppercase tracking-[0.2em] text-teal-200 leading-none">SPP APP</p>
				<p class="text-sm font-bold leading-tight">SMK Wijayakusuma</p>
			</div>
		</header>

		<!-- Overlay (mobile only) -->
		<div
			id="sidebar-overlay"
			class="fixed inset-0 z-40 bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
			aria-hidden="true"
		></div>

		<!-- Layout Wrapper -->
		<div class="lg:mx-auto lg:grid lg:min-h-screen lg:max-w-7xl lg:grid-cols-[260px_1fr] lg:gap-4 lg:p-4">

			<!-- Sidebar: drawer pada mobile, kolom grid pada desktop -->
			<aside
				id="sidebar"
				class="fixed top-0 left-0 z-50 flex h-screen w-[260px] -translate-x-full flex-col overflow-y-auto bg-[var(--ink)] p-5 text-white shadow-xl transition-transform duration-300 lg:static lg:h-auto lg:translate-x-0 lg:overflow-visible lg:rounded-2xl lg:[transition:none]"
			>
				<!-- Tombol tutup sidebar (mobile only) -->
				<button
					id="sidebar-close"
					aria-label="Tutup menu"
					class="absolute right-3 top-3 rounded-lg p-1.5 hover:bg-white/10 transition-colors lg:hidden"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>

				<div>
					<p class="text-xs uppercase tracking-[0.2em] text-teal-200">SPP APP</p>
					<h1 class="mt-1 text-2xl font-black leading-tight">SMK Wijayakusuma</h1>
					<nav class="mt-8 space-y-1 text-sm">
						<a class={navLink("/")} href="/">Dashboard</a>

						<p class="px-3 pt-4 pb-1 text-xs uppercase tracking-[0.14em] text-teal-200">Master</p>
						<a class={navLink("/master/siswa")} href="/master/siswa">Siswa</a>
						<a class={navLink("/master/kelas")} href="/master/kelas">Kelas</a>
						<a class={navLink("/master/komponen")} href="/master/komponen">Komponen Biaya</a>
						<a class={navLink("/master/periode")} href="/master/periode">Tahun Ajaran & Periode</a>

						<p class="px-3 pt-4 pb-1 text-xs uppercase tracking-[0.14em] text-teal-200">Transaksi</p>
						<a class={navLink("/tagihan")} href="/tagihan">Tagihan Siswa</a>
						<a class={navLink("/pembayaran/virtual-akun")} href="/pembayaran/virtual-akun">Virtual Akun Bank</a>
						<a class={navLink("/pembayaran")} href="/pembayaran">Pembayaran Tunai</a>
						<a class={navLink("/laporan")} href="/laporan">Laporan</a>
						<a class={navLink("/laporan/mutasi")} href="/laporan/mutasi">Mutasi</a>

						<!-- Admin-only section: disembunyikan, ditampilkan via JS jika role=admin -->
						<div id="admin-nav" class="hidden">
							<p class="px-3 pt-4 pb-1 text-xs uppercase tracking-[0.14em] text-yellow-300">Administrator</p>
							<a class={navLink("/admin/pengguna")} href="/admin/pengguna">Kelola Pengguna</a>
							<a class={navLink("/admin/koreksi")} href="/admin/koreksi">Koreksi Data</a>
							<a class={navLink("/admin/rekening")} href="/admin/rekening">Rekening Bank</a>
						</div>
					</nav>
				</div>

				<!-- User info + logout -->
				<div class="mt-auto border-t border-white/10 pt-6">
					<div class="mb-1 flex items-center gap-2">
						<span id="sidebar-role-badge" class="hidden rounded-full px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide"></span>
					</div>
					<p id="sidebar-email" class="mb-2 truncate text-xs text-teal-200"></p>
					<button
						id="logout-btn"
						class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-sm hover:bg-white/10 transition-colors text-left"
					>
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
							<path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 001 1h7a1 1 0 000-2H4V5h6a1 1 0 000-2H3zm10.293 4.293a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 01-1.414-1.414L14.586 11H7a1 1 0 110-2h7.586l-1.293-1.293a1 1 0 010-1.414z" clip-rule="evenodd" />
						</svg>
						Keluar
					</button>
				</div>
			</aside>

			<!-- Konten Utama -->
			<main class="min-h-[calc(100vh-56px)] bg-[var(--surface)] p-4 shadow-none sm:p-6 lg:min-h-0 lg:rounded-2xl lg:shadow-xl">
				<slot />
			</main>
		</div>

		<script>
			import { supabase } from "../lib/supabase";

			// ─── Auth guard + role ────────────────────────────────────────────────
			const { data: { session } } = await supabase.auth.getSession();
			if (!session) {
				window.location.href = "/login";
			} else {
				const emailEl = document.getElementById("sidebar-email");
				if (emailEl) emailEl.textContent = session.user.email ?? "";

				// Ambil profil & role
				let role = "kasir";
				const { data: profile } = await supabase
					.from("user_profiles")
					.select("role, full_name")
					.eq("user_id", session.user.id)
					.single();

				if (!profile) {
					// Auto-buat profil kasir untuk user baru
					await supabase.from("user_profiles").upsert({
						user_id: session.user.id,
						email: session.user.email ?? "",
						role: "kasir",
					});
				} else {
					role = profile.role ?? "kasir";
				}

				// Simpan role global untuk cek di halaman
				(window as any).__userRole = role;

				// Tampilkan badge role
				const badge = document.getElementById("sidebar-role-badge");
				if (badge) {
					badge.textContent = role === "admin" ? "Administrator" : "Kasir";
					badge.className = role === "admin"
						? "rounded-full px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide bg-yellow-400 text-yellow-900"
						: "rounded-full px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide bg-teal-500/30 text-teal-200";
					badge.classList.remove("hidden");
				}

				// Tampilkan nav admin jika role=admin
				if (role === "admin") {
					document.getElementById("admin-nav")?.classList.remove("hidden");
				}
			}

			supabase.auth.onAuthStateChange((event, session) => {
				if (event === "SIGNED_OUT" || (event === "TOKEN_REFRESHED" && !session)) {
					window.location.href = "/login";
				}
			});

			document.getElementById("logout-btn")?.addEventListener("click", async () => {
				await supabase.auth.signOut();
				window.location.href = "/login";
			});

			// ─── Mobile sidebar toggle ─────────────────────────────────────────────
			const sidebar = document.getElementById("sidebar");
			const overlay = document.getElementById("sidebar-overlay");
			const menuToggle = document.getElementById("menu-toggle");
			const sidebarClose = document.getElementById("sidebar-close");

			function openSidebar() {
				sidebar?.classList.remove("-translate-x-full");
				sidebar?.classList.add("translate-x-0");
				if (overlay) {
					overlay.classList.remove("opacity-0", "pointer-events-none");
					overlay.classList.add("opacity-100");
				}
				document.body.style.overflow = "hidden";
			}

			function closeSidebar() {
				sidebar?.classList.add("-translate-x-full");
				sidebar?.classList.remove("translate-x-0");
				if (overlay) {
					overlay.classList.add("opacity-0", "pointer-events-none");
					overlay.classList.remove("opacity-100");
				}
				document.body.style.overflow = "";
			}

			menuToggle?.addEventListener("click", openSidebar);
			sidebarClose?.addEventListener("click", closeSidebar);
			overlay?.addEventListener("click", closeSidebar);

			sidebar?.querySelectorAll("a").forEach((link) => {
				link.addEventListener("click", () => {
					if (window.innerWidth < 1024) closeSidebar();
				});
			});
		</script>
	</body>
</html>
